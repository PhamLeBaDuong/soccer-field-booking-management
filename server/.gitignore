/src/generated/
# SQLite dev database (if ever used locally)
prisma/dev.db
prisma/dev.db-journal
*.db
*.db-journal

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- OS & editor noise ----
.DS_Store
Thumbs.db
*.pem
*.key
