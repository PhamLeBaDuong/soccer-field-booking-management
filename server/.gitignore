# ---- Dependencies ----
node_modules/

# ---- Build output ----
/dist
/build

# ---- Environment variables ----
# Commit .env.example; never commit real secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ---- Prisma ----
