generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String       @id @default(uuid())
  name            String
  username        String       @unique
  email           String       @unique
  phone           String?
  password        String?
  role            String       @default("player")
  metadata        Json?
  createdAt       DateTime     @default(now())
  bookings        Booking[]
  complexes       Complex[]    @relation("owner_complexes")
  fields          Field[]      @relation("owner_fields")
  createdLobbies  Lobby[]      @relation("lobby_creator")
  lobbySlots      LobbySlot[]
  ledTeams        Team[]       @relation("team_leader")
  teamMemberships TeamMember[]

  sentFriendRequests     Friendship[] @relation("friendship_sender")
  receivedFriendRequests Friendship[] @relation("friendship_receiver")
  sentMessages           ChatMessage[] @relation("message_sender")
  receivedMessages       ChatMessage[] @relation("message_receiver")
  sentInvites            TeamInvite[] @relation("invite_sender")
  receivedInvites        TeamInvite[] @relation("invite_receiver")
}

model Complex {
  id        String   @id @default(uuid())
  name      String
  desc      String?
  address   String?
  lat       Float?
  lng       Float?
  metadata  Json?
  createdAt DateTime @default(now())
  ownerId   String?
  owner     User?    @relation("owner_complexes", fields: [ownerId], references: [id])
  fields    Field[]

  @@index([ownerId])
}

model Field {
  id           String      @id @default(uuid())
  ownerId      String?
  complexId    String
  name         String
  desc         String?
  address      String?
  type         String?
  startTime    DateTime
  endTime      DateTime
  indoor       Boolean     @default(false)
  lights       Boolean     @default(false)
  pricePerHour Float       @default(0)
  metadata     Json?
  createdAt    DateTime    @default(now())
  bookings     Booking[]
  complex      Complex     @relation(fields: [complexId], references: [id])
  owner        User?       @relation("owner_fields", fields: [ownerId], references: [id])
  lobbies      Lobby[]
  matchPosts   MatchPost[]
}

model Team {
  id         String       @id @default(uuid())
  name       String
  size       Int
  rating     Float        @default(0)
  leaderId   String
  createdAt  DateTime     @default(now())
  matchPosts MatchPost[]
  leader     User         @relation("team_leader", fields: [leaderId], references: [id])
  members    TeamMember[]
  invites    TeamInvite[]

  @@index([leaderId])
}

model TeamMember {
  id       String   @id @default(uuid())
  teamId   String
  userId   String
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model MatchPost {
  id                 String    @id @default(uuid())
  teamId             String
  fieldId            String?
  lat                Float?
  lng                Float?
  preferredStartTime DateTime?
  preferredEndTime   DateTime?
  visibility         String    @default("public")
  code               String?   @unique
  status             String    @default("open")
  note               String?
  createdAt          DateTime  @default(now())
  match              Match?    @relation("post_match")
  field              Field?    @relation(fields: [fieldId], references: [id])
  team               Team      @relation(fields: [teamId], references: [id])

  @@index([teamId])
  @@index([status, visibility])
}

model Lobby {
  id          String      @id @default(uuid())
  fieldId     String
  startTime   DateTime
  endTime     DateTime
  teamSize    Int
  initialSize Int         @default(1)
  creatorId   String
  status      String      @default("open")
  visibility  String      @default("public")
  code        String?
  matchId     String?
  createdAt   DateTime    @default(now())
  creator     User        @relation("lobby_creator", fields: [creatorId], references: [id])
  field       Field       @relation(fields: [fieldId], references: [id])
  match       Match?      @relation("lobby_matches", fields: [matchId], references: [id])
  slots       LobbySlot[]

  @@index([fieldId, startTime])
  @@index([status])
  @@index([teamSize, status, fieldId])
}

model LobbySlot {
  id       String   @id @default(uuid())
  lobbyId  String
  userId   String
  joinedAt DateTime @default(now())
  lobby    Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([lobbyId, userId])
  @@index([lobbyId])
  @@index([userId])
}

// Match result scores are set post-match by the venue admin.
// "home" = the team/lobby that posted first; "away" = the accepter.
model Match {
  id          String     @id @default(uuid())
  source      String
  status      String     @default("confirmed")
  fieldId     String
  startTime   DateTime
  endTime     DateTime
  homeScore   Int?
  awayScore   Int?
  resultNote  String?
  matchPostId String?    @unique
  createdAt   DateTime   @default(now())
  bookings    Booking[]
  lobbies     Lobby[]    @relation("lobby_matches")
  matchPost   MatchPost? @relation("post_match", fields: [matchPostId], references: [id])

  @@index([fieldId, startTime])
  @@index([status])
}

model Booking {
  id         String   @id @default(uuid())
  userId     String
  fieldId    String
  matchId    String
  startTime  DateTime
  endTime    DateTime
  totalPrice Float    @default(0)
  currency   String   @default("VND")
  status     String   @default("confirmed")
  createdAt  DateTime @default(now())
  field      Field    @relation(fields: [fieldId], references: [id])
  match      Match    @relation(fields: [matchId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([fieldId, startTime, endTime])
  @@index([matchId])
}

// ─────────────────────────────────────────────────────────────────────────────
//  Friendship
//  status: "pending" | "accepted" | "declined"
// ─────────────────────────────────────────────────────────────────────────────
model Friendship {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("friendship_sender", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("friendship_receiver", fields: [receiverId], references: [id])
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

// ─────────────────────────────────────────────────────────────────────────────
//  ChatMessage  –  direct messages between two users
// ─────────────────────────────────────────────────────────────────────────────
model ChatMessage {
  id         String    @id @default(uuid())
  senderId   String
  sender     User      @relation("message_sender", fields: [senderId], references: [id])
  receiverId String
  receiver   User      @relation("message_receiver", fields: [receiverId], references: [id])
  content    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([senderId, receiverId])
  @@index([receiverId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
//  TeamInvite  –  a member invites another user to join a team
//  status: "pending" | "accepted" | "declined"
// ─────────────────────────────────────────────────────────────────────────────
model TeamInvite {
  id          String   @id @default(uuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User     @relation("invite_sender", fields: [invitedById], references: [id])
  inviteeId   String
  invitee     User     @relation("invite_receiver", fields: [inviteeId], references: [id])
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  @@unique([teamId, inviteeId])
  @@index([teamId])
  @@index([inviteeId])
  @@index([invitedById])
}
