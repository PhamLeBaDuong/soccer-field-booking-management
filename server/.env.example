# Copy to .env for local runs. In hosting, set these as the platform's env vars.

# Full Postgres connection string (Prisma reads only this one).
# Hosted Postgres (Neon etc.) needs SSL — keep ?sslmode=require.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/soccer_booking?schema=public"

# Secret used to sign JWTs — use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-string"

# Port the API listens on (hosts usually inject their own PORT).
PORT=5000

# Frontend origin allowed by CORS and Socket.io (your deployed frontend URL).
CLIENT_URL="http://localhost:3000"

# ── Cleanup sweep ────────────────────────────────────────────────────────
# Removes expired lobbies/posts/matches. Each run queries the DB, so a short
# interval keeps a scale-to-zero DB (Neon free tier) awake and burns compute.
# Minutes between sweeps (default 30). Bump to 60 to be even gentler.
CLEANUP_INTERVAL_MIN=30
# Set to false to disable the in-process sweep (e.g. run it via an external cron).
CLEANUP_ENABLED=true
