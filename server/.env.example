# Copy to .env for local runs. In hosting, set these as the platform's env vars.
# Full Postgres connection string (Prisma reads only this one).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/soccer_booking?schema=public"

# Secret used to sign JWTs — use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-string"

# Port the API listens on (hosts usually inject their own PORT).
PORT=5000

# Frontend URL — used to build Stripe success/cancel redirect URLs.
CLIENT_URL="http://localhost:3000"

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Webhook signing secret from https://dashboard.stripe.com/webhooks
# For local testing: stripe listen --forward-to localhost:5000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── PayPal ────────────────────────────────────────────────────────────────────
# Get these from https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID="..."
PAYPAL_CLIENT_SECRET="..."
# "sandbox" for testing, "live" for production
PAYPAL_MODE="sandbox"

# ── MoMo ─────────────────────────────────────────────────────────────────────
# Register at https://business.momo.vn → Integration → Create App
MOMO_PARTNER_CODE="..."
MOMO_ACCESS_KEY="..."
MOMO_SECRET_KEY="..."
# "sandbox" for testing (default), "live" for production
MOMO_ENV="sandbox"

# ── VNPay ─────────────────────────────────────────────────────────────────────
# Register at https://sandbox.vnpayment.vn/devreg/ (sandbox) or https://vnpay.vn (live)
VNPAY_TMN_CODE="..."
VNPAY_HASH_SECRET="..."
# "sandbox" for testing (default), "live" for production
VNPAY_ENV="sandbox"

# ── ZaloPay ───────────────────────────────────────────────────────────────────
# Register at https://developers.zalopay.vn
ZALOPAY_APP_ID="..."
ZALOPAY_KEY1="..."
ZALOPAY_KEY2="..."
# "sandbox" for testing (default), "live" for production
ZALOPAY_ENV="sandbox"

# ── Public API URL (used for IPN/webhook callbacks from payment providers) ───
# For local testing: use ngrok or similar tunnel → e.g. https://abc123.ngrok.io
# In production: your actual API domain → e.g. https://api.pitchbook.vn
API_URL="http://localhost:5000"
