# Copy to .env for local runs. In hosting, set these as the platform's env vars.
# Full Postgres connection string (Prisma reads only this one).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/soccer_booking?schema=public"

# Secret used to sign JWTs — use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-string"

# Port the API listens on (hosts usually inject their own PORT).
PORT=5000
