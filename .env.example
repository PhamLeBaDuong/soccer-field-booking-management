# Copy to ".env" (same folder as docker-compose.yml) and fill in.
# Docker Compose auto-loads .env. Do NOT commit the real .env.
# All values are optional — docker-compose.yml has localhost defaults.

# ── URLs (override for a real deployment; localhost is fine for local dev) ──
# CLIENT_URL          = frontend origin the API allows for CORS / Socket.io
# NEXT_PUBLIC_API_URL = URL the browser calls the API at (baked into web at build)
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000

# ── App secrets (override the dev defaults for a real deployment) ─────────
POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-long-random-string
