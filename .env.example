# Copy to ".env" (same folder as docker-compose.yml) and fill in.
# Docker Compose auto-loads .env. Do NOT commit the real .env.

# ── Public URLs served by your Cloudflare Tunnel ─────────────────────────
# These must match the Public Hostnames you create in the Zero Trust dashboard.
PUBLIC_WEB_URL=https://app.yourdomain.com
PUBLIC_API_URL=https://api.yourdomain.com

# ── Cloudflare Tunnel ────────────────────────────────────────────────────
# Zero Trust → Networks → Tunnels → create a tunnel → copy its token.
CLOUDFLARE_TUNNEL_TOKEN=

# ── App secrets (override the dev defaults for a real deployment) ─────────
POSTGRES_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-long-random-string
